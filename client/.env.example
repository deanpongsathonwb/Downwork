# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env.development.local for local dev overrides.
#
# Variables prefixed with VITE_ are exposed to the client bundle.
# Do NOT put secrets in VITE_ variables — they will be public!
# ============================================================

# ── APPLICATION ──────────────────────────────────────────────
VITE_APP_NAME=Downwork
VITE_APP_URL=http://localhost:1997

# ── API ──────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ── MOCK MODE ────────────────────────────────────────────────
# "true"  = use built-in mock data (no backend needed)
# "false" = call real backend API
VITE_USE_MOCK=true

# ── AUTH ─────────────────────────────────────────────────────
VITE_USE_COOKIE_AUTH=false

# ── FEATURES ─────────────────────────────────────────────────
VITE_ENABLE_2FA=true
VITE_ENABLE_ANALYTICS=false
# Toast popups (login, logout, API errors, etc.). Omit or "false" = disabled app-wide.
# VITE_ENABLE_TOASTS=true

# ── ERROR TRACKING (Optional) ────────────────────────────────
VITE_SENTRY_DSN=
