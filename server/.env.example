# Database — PostgreSQL only (no Docker required).
# Option A: Neon https://neon.tech — create project, paste connection string below.
# Option B: Install PostgreSQL on your OS, create database `downwork`, use postgresql://USER:PASSWORD@localhost:5432/downwork
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/downwork?sslmode=require"

# JWT — CHANGE THESE IN PRODUCTION (use: openssl rand -hex 32)
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# App
PORT=3000
# Dev only: when NODE_ENV != production, skip auto kill-port preflight (two APIs on same port, etc.)
# DEV_SKIP_FREE_PORT=true
NODE_ENV=production
CORS_ORIGIN=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Email (console | smtp)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@downwork.online
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Storage (local | s3)
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
CDN_URL=

# Redis (Optional — ไม่ต้องตั้งก็ใช้งานได้ปกติ)
# เปิดเพื่อใช้ caching + background job queue (BullMQ)
# REDIS_URL=redis://localhost:6379

# Sentry (Optional)
SENTRY_DSN=
